import sys
from pathlib import Path

# Add the WA-OS repository root to the import path.
ROOT_DIR = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(ROOT_DIR))

from wa_os_runtime import WAOSRuntime

def run_news_framing_analysis_example() -> None:
    """
    Example 01: Multi-perspective news framing analysis using WA-OS.
    This example demonstrates how WA-OS separates claims, evidence,
    stakeholder incentives, uncertainty, and rhetorical framing without
    reducing a complex issue to a binary true-or-false judgment.
    """
    # 1. Initialize the WA-OS runtime and generate the system prompt.
    protocol_path = ROOT_DIR / "wa-os.protocol.json"
    runtime = WAOSRuntime(protocol_path=str(protocol_path))
    system_prompt = runtime.generate_system_prompt()

    # 2. Sample news text to be analyzed.
    sample_news_input = """
[Sample News Text]
Country A announced today that it will establish a special economic zone
near its border with a neighboring country.
Government officials supporting the project described it as
"a historic achievement that will dramatically revitalize the regional
economy and create employment."
Meanwhile, local environmental organizations and some residents have
called for the project to be suspended. They argue that an adequate
environmental assessment has not been conducted and express concern
about damage to the region's unique ecosystem and traditional industries.
""".strip()

    # 3. Construct the user prompt to be sent to an LLM.
    user_instruction = f"""
=== TASK ===
Analyze the following news text using the WA-OS Execution Framework.
Do not reduce the issue to a binary judgment such as "true" or "false".
Do not declare any stakeholder inherently correct or incorrect.

Clearly distinguish:
1. Neutral event summary
2. Stakeholders
3. Explicit claims
4. Available evidence
5. Missing or unverified evidence
6. Stakeholder incentives and interests
7. Rhetorical or emotional framing
8. Plausible alternative interpretations
9. Uncertainty and verification needs
10. Points that require human judgment

=== INPUT TEXT ===
{sample_news_input}
""".strip()

    print("=" * 50)
    print("WA-OS Example 01: News Framing Analysis")
    print("=" * 50)
    print("\n[Generated System Prompt Preview]")
    preview_length = 500
    print(system_prompt[:preview_length])
    if len(system_prompt) > preview_length:
        print("\n... (truncated for preview)")

    print("\n" + "=" * 50)
    print("[Constructed User Prompt]")
    print(user_instruction)
    print("\n" + "=" * 50)
    print(
        "Ready to pass to an LLM provider, "
        "such as OpenAI, Anthropic, or Google."
    )

if __name__ == "__main__":
    run_news_framing_analysis_example()
